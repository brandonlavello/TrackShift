{
  "name": "trackshift",
  "version": "0.1.0",
  "description": "TrackShift — correct Garmin FIT/GPX tracks recorded on a moving ship. Client-side Vue app.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pages": "GITHUB_PAGES=true vite build",
    "preview": "vite preview --port 5050",
    "test": "vitest run",
    "lint": "eslint . --fix",
    "prepare": "git config core.hooksPath .githooks && chmod +x .githooks/commit-msg 2>/dev/null || true"
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "fit-file-parser": "^2.1.1",
    "pinia": "^2.3.0",
    "vue": "~3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.21.0",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^16.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vite": "^6.0.7",
    "vitest": "^3.0.7",
    "vue-eslint-parser": "^9.4.3"
  }
}
